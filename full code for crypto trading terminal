<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NEXUS — Crypto Trading Terminal</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg0: #080b10;
    --bg1: #0d1117;
    --bg2: #111820;
    --bg3: #151d28;
    --bg4: #1a2433;
    --border: rgba(255,255,255,0.06);
    --border2: rgba(255,255,255,0.1);
    --text1: #e8edf2;
    --text2: #8899aa;
    --text3: #4a5c6e;
    --green: #00e8a2;
    --green-dim: rgba(0,232,162,0.12);
    --red: #ff4d6a;
    --red-dim: rgba(255,77,106,0.12);
    --blue: #3b9eff;
    --blue-dim: rgba(59,158,255,0.1);
    --amber: #f7b731;
    --amber-dim: rgba(247,183,49,0.1);
    --purple: #9b7ff4;
    --mono: 'Space Mono', monospace;
    --sans: 'DM Sans', sans-serif;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg0); color: var(--text1); font-family: var(--sans); font-size: 13px; overflow-x: hidden; }

  /* TOPBAR */
  .topbar {
    display: flex; align-items: center; gap: 0;
    background: var(--bg1); border-bottom: 1px solid var(--border);
    height: 44px; padding: 0 16px; position: sticky; top: 0; z-index: 100;
  }
  .logo { font-family: var(--mono); font-size: 13px; font-weight: 700; letter-spacing: 0.15em; color: var(--text1); margin-right: 24px; }
  .logo span { color: var(--green); }
  .ticker-strip { display: flex; gap: 0; flex: 1; overflow: hidden; }
  .ticker-item {
    display: flex; align-items: center; gap: 8px;
    padding: 0 14px; height: 44px; cursor: pointer;
    border-right: 1px solid var(--border);
    transition: background 0.15s;
    white-space: nowrap;
  }
  .ticker-item:hover { background: var(--bg3); }
  .ticker-item.active { background: var(--bg3); border-bottom: 2px solid var(--green); }
  .ticker-sym { font-family: var(--mono); font-size: 11px; font-weight: 700; color: var(--text2); }
  .ticker-price { font-family: var(--mono); font-size: 12px; color: var(--text1); }
  .ticker-change { font-family: var(--mono); font-size: 10px; }
  .up { color: var(--green); }
  .dn { color: var(--red); }
  .topbar-right { display: flex; align-items: center; gap: 12px; margin-left: 16px; }
  .pill { font-size: 11px; font-family: var(--mono); padding: 3px 10px; border-radius: 20px; border: 1px solid var(--border2); color: var(--text2); }
  .pill.live { border-color: var(--green); color: var(--green); animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.5} }

  /* LAYOUT */
  .layout { display: grid; grid-template-columns: 1fr 320px 280px; grid-template-rows: auto 1fr; height: calc(100vh - 44px); gap: 1px; background: var(--border); }
  .panel { background: var(--bg1); overflow: hidden; }

  /* CHART PANEL */
  .chart-panel { grid-row: 1 / 3; display: flex; flex-direction: column; }
  .chart-header { display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-bottom: 1px solid var(--border); flex-shrink: 0; }
  .pair-name { font-family: var(--mono); font-size: 16px; font-weight: 700; color: var(--text1); }
  .pair-price { font-family: var(--mono); font-size: 22px; font-weight: 700; color: var(--green); }
  .pair-meta { display: flex; flex-direction: column; gap: 2px; margin-left: auto; }
  .meta-row { display: flex; gap: 16px; }
  .meta-item { display: flex; flex-direction: column; align-items: flex-end; }
  .meta-label { font-size: 10px; color: var(--text3); font-family: var(--mono); text-transform: uppercase; letter-spacing: 0.08em; }
  .meta-val { font-family: var(--mono); font-size: 12px; color: var(--text2); }
  .timeframe-tabs { display: flex; gap: 0; padding: 8px 16px; border-bottom: 1px solid var(--border); flex-shrink: 0; }
  .tf-btn {
    font-family: var(--mono); font-size: 11px; padding: 4px 10px; cursor: pointer;
    background: transparent; border: 1px solid transparent; color: var(--text3);
    border-radius: 4px; transition: all 0.15s;
  }
  .tf-btn:hover { color: var(--text2); border-color: var(--border2); }
  .tf-btn.active { background: var(--bg3); color: var(--green); border-color: var(--green); }
  .chart-area { flex: 1; position: relative; padding: 16px; min-height: 0; }
  .chart-area canvas { width: 100% !important; }

  /* INDICATOR ROW */
  .indicators { display: flex; gap: 0; border-top: 1px solid var(--border); flex-shrink: 0; }
  .ind-item { flex: 1; padding: 8px 12px; border-right: 1px solid var(--border); }
  .ind-item:last-child { border-right: none; }
  .ind-label { font-size: 10px; color: var(--text3); font-family: var(--mono); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 2px; }
  .ind-val { font-family: var(--mono); font-size: 12px; }

  /* ORDERBOOK */
  .orderbook-panel { display: flex; flex-direction: column; }
  .panel-header { display: flex; align-items: center; justify-content: space-between; padding: 10px 14px; border-bottom: 1px solid var(--border); flex-shrink: 0; }
  .panel-title { font-family: var(--mono); font-size: 11px; font-weight: 700; letter-spacing: 0.1em; color: var(--text2); text-transform: uppercase; }
  .spread-badge { font-family: var(--mono); font-size: 10px; color: var(--amber); border: 1px solid var(--amber); border-radius: 3px; padding: 2px 6px; }
  .ob-headers { display: grid; grid-template-columns: 1fr 1fr 1fr; padding: 6px 14px; }
  .ob-head { font-family: var(--mono); font-size: 10px; color: var(--text3); text-transform: uppercase; letter-spacing: 0.06em; }
  .ob-head:last-child { text-align: right; }
  .ob-head:nth-child(2) { text-align: center; }
  .ob-rows { flex: 1; overflow-y: auto; scrollbar-width: none; }
  .ob-rows::-webkit-scrollbar { display: none; }
  .ob-row { display: grid; grid-template-columns: 1fr 1fr 1fr; padding: 3px 14px; position: relative; transition: background 0.1s; }
  .ob-row:hover { background: var(--bg3); }
  .ob-bar { position: absolute; top: 0; bottom: 0; opacity: 0.12; border-radius: 2px; }
  .ob-bar.ask { right: 0; background: var(--red); }
  .ob-bar.bid { right: 0; background: var(--green); }
  .ob-price { font-family: var(--mono); font-size: 11px; }
  .ob-price.ask { color: var(--red); }
  .ob-price.bid { color: var(--green); }
  .ob-size { font-family: var(--mono); font-size: 11px; color: var(--text2); text-align: center; }
  .ob-total { font-family: var(--mono); font-size: 11px; color: var(--text3); text-align: right; }
  .ob-mid { text-align: center; padding: 6px 14px; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); background: var(--bg2); flex-shrink: 0; }
  .ob-mid-price { font-family: var(--mono); font-size: 14px; font-weight: 700; color: var(--green); }
  .ob-mid-usd { font-family: var(--mono); font-size: 11px; color: var(--text3); }

  /* TRADE HISTORY */
  .trade-panel { display: flex; flex-direction: column; }
  .trade-rows { flex: 1; overflow-y: auto; scrollbar-width: none; }
  .trade-rows::-webkit-scrollbar { display: none; }
  .trade-row { display: grid; grid-template-columns: 1fr 1fr 1fr; padding: 4px 14px; }
  .trade-row:hover { background: var(--bg3); }
  .tr-price { font-family: var(--mono); font-size: 11px; }
  .tr-size { font-family: var(--mono); font-size: 11px; color: var(--text2); text-align: center; }
  .tr-time { font-family: var(--mono); font-size: 11px; color: var(--text3); text-align: right; }

  /* PORTFOLIO */
  .portfolio-panel { display: flex; flex-direction: column; }
  .port-summary { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--border); flex-shrink: 0; }
  .port-stat { background: var(--bg2); padding: 10px 14px; }
  .port-stat-label { font-size: 10px; color: var(--text3); font-family: var(--mono); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 3px; }
  .port-stat-val { font-family: var(--mono); font-size: 13px; font-weight: 700; }
  .port-holdings { flex: 1; overflow-y: auto; scrollbar-width: none; }
  .port-holdings::-webkit-scrollbar { display: none; }
  .holding-row { display: flex; align-items: center; gap: 10px; padding: 9px 14px; border-bottom: 1px solid var(--border); cursor: pointer; transition: background 0.1s; }
  .holding-row:hover { background: var(--bg3); }
  .holding-icon { width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: var(--mono); font-size: 9px; font-weight: 700; flex-shrink: 0; }
  .holding-info { flex: 1; }
  .holding-sym { font-family: var(--mono); font-size: 12px; font-weight: 700; }
  .holding-name { font-size: 11px; color: var(--text3); }
  .holding-right { text-align: right; }
  .holding-val { font-family: var(--mono); font-size: 12px; }
  .holding-pnl { font-family: var(--mono); font-size: 11px; }
  .holding-bar { height: 2px; background: var(--bg4); border-radius: 1px; margin: 0 14px 0; overflow: hidden; }
  .holding-bar-fill { height: 100%; border-radius: 1px; }

  /* TRADE FORM */
  .trade-form { flex-shrink: 0; border-top: 1px solid var(--border); }
  .trade-tabs { display: flex; border-bottom: 1px solid var(--border); }
  .trade-tab { flex: 1; padding: 8px; text-align: center; font-family: var(--mono); font-size: 11px; font-weight: 700; letter-spacing: 0.08em; cursor: pointer; border: none; background: transparent; color: var(--text3); transition: all 0.15s; }
  .trade-tab.buy.active { color: var(--green); border-bottom: 2px solid var(--green); }
  .trade-tab.sell.active { color: var(--red); border-bottom: 2px solid var(--red); }
  .trade-body { padding: 12px 14px; }
  .form-group { margin-bottom: 10px; }
  .form-label { font-size: 10px; color: var(--text3); font-family: var(--mono); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 4px; display: flex; justify-content: space-between; }
  .form-input { width: 100%; background: var(--bg0); border: 1px solid var(--border2); border-radius: 4px; padding: 7px 10px; color: var(--text1); font-family: var(--mono); font-size: 12px; outline: none; transition: border-color 0.15s; }
  .form-input:focus { border-color: var(--green); }
  .pct-row { display: flex; gap: 6px; margin-bottom: 10px; }
  .pct-btn { flex: 1; background: var(--bg3); border: 1px solid var(--border); border-radius: 3px; padding: 4px; text-align: center; font-family: var(--mono); font-size: 10px; color: var(--text3); cursor: pointer; transition: all 0.15s; }
  .pct-btn:hover { border-color: var(--green); color: var(--green); }
  .submit-btn { width: 100%; padding: 9px; border-radius: 4px; border: none; font-family: var(--mono); font-size: 12px; font-weight: 700; letter-spacing: 0.08em; cursor: pointer; transition: all 0.15s; }
  .submit-btn.buy { background: var(--green); color: #000; }
  .submit-btn.sell { background: var(--red); color: #fff; }
  .submit-btn:hover { opacity: 0.85; transform: translateY(-1px); }
  .submit-btn:active { transform: translateY(0); }

  /* NEWS PANEL */
  .news-panel { display: flex; flex-direction: column; }
  .news-list { flex: 1; overflow-y: auto; scrollbar-width: thin; scrollbar-color: var(--border2) transparent; }
  .news-item { padding: 11px 14px; border-bottom: 1px solid var(--border); cursor: pointer; transition: background 0.1s; }
  .news-item:hover { background: var(--bg3); }
  .news-meta { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
  .news-source { font-family: var(--mono); font-size: 10px; color: var(--blue); }
  .news-time { font-family: var(--mono); font-size: 10px; color: var(--text3); }
  .news-sentiment { font-size: 10px; padding: 1px 6px; border-radius: 2px; font-family: var(--mono); }
  .news-sentiment.bull { background: var(--green-dim); color: var(--green); }
  .news-sentiment.bear { background: var(--red-dim); color: var(--red); }
  .news-sentiment.neut { background: var(--bg4); color: var(--text3); }
  .news-headline { font-size: 12px; color: var(--text1); line-height: 1.45; }
  .news-coins { display: flex; gap: 4px; margin-top: 5px; }
  .news-coin-tag { font-family: var(--mono); font-size: 10px; color: var(--text3); background: var(--bg3); padding: 1px 5px; border-radius: 2px; }

  /* SCROLLBAR STYLE */
  ::-webkit-scrollbar { width: 3px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }

  /* RESPONSIVE clamp for very small heights */
  @media (max-height: 700px) { .layout { height: auto; min-height: 700px; } }

  /* TOAST */
  .toast { position: fixed; bottom: 24px; right: 24px; background: var(--bg3); border: 1px solid var(--green); color: var(--green); font-family: var(--mono); font-size: 12px; padding: 10px 18px; border-radius: 6px; z-index: 999; opacity: 0; transform: translateY(8px); transition: all 0.25s; pointer-events: none; }
  .toast.show { opacity: 1; transform: translateY(0); }
</style>
</head>
<body>

<!-- TOPBAR -->
<div class="topbar">
  <div class="logo">NEX<span>US</span></div>
  <div class="ticker-strip" id="tickerStrip"></div>
  <div class="topbar-right">
    <div class="pill live">● LIVE</div>
    <div class="pill">TESTNET</div>
  </div>
</div>

<!-- MAIN LAYOUT -->
<div class="layout">

  <!-- CHART PANEL -->
  <div class="panel chart-panel">
    <div class="chart-header">
      <div>
        <div class="pair-name" id="pairName">BTC / USDT</div>
        <div style="font-size:11px;color:var(--text3);font-family:var(--mono);">BINANCE</div>
      </div>
      <div style="margin-left:16px;">
        <div class="pair-price" id="pairPrice">67,432.50</div>
        <div style="display:flex;gap:8px;align-items:center;margin-top:2px;">
          <span class="up" id="pairChange" style="font-family:var(--mono);font-size:12px;">+2.34%</span>
          <span style="font-family:var(--mono);font-size:11px;color:var(--text3);">24h</span>
        </div>
      </div>
      <div class="pair-meta">
        <div class="meta-row">
          <div class="meta-item">
            <span class="meta-label">24h High</span>
            <span class="meta-val up" id="high24">68,200.00</span>
          </div>
          <div class="meta-item">
            <span class="meta-label">24h Low</span>
            <span class="meta-val dn" id="low24">65,890.00</span>
          </div>
          <div class="meta-item">
            <span class="meta-label">24h Vol</span>
            <span class="meta-val">42,318 BTC</span>
          </div>
          <div class="meta-item">
            <span class="meta-label">Mkt Cap</span>
            <span class="meta-val">$1.32T</span>
          </div>
        </div>
      </div>
    </div>
    <div class="timeframe-tabs">
      <button class="tf-btn" onclick="setTF('1m')">1m</button>
      <button class="tf-btn" onclick="setTF('5m')">5m</button>
      <button class="tf-btn" onclick="setTF('15m')">15m</button>
      <button class="tf-btn" onclick="setTF('1h')">1H</button>
      <button class="tf-btn active" onclick="setTF('4h')">4H</button>
      <button class="tf-btn" onclick="setTF('1d')">1D</button>
      <button class="tf-btn" onclick="setTF('1w')">1W</button>
    </div>
    <div class="chart-area" id="chartArea">
      <canvas id="priceChart"></canvas>
    </div>
    <div class="indicators">
      <div class="ind-item"><div class="ind-label">RSI (14)</div><div class="ind-val" style="color:var(--amber)">61.4</div></div>
      <div class="ind-item"><div class="ind-label">MACD</div><div class="ind-val up">+142.3</div></div>
      <div class="ind-item"><div class="ind-label">MA (20)</div><div class="ind-val" style="color:var(--purple)">66,812</div></div>
      <div class="ind-item"><div class="ind-label">MA (50)</div><div class="ind-val" style="color:var(--blue)">63,440</div></div>
      <div class="ind-item"><div class="ind-label">Vol (24h)</div><div class="ind-val">$2.84B</div></div>
      <div class="ind-item"><div class="ind-label">Funding</div><div class="ind-val up">+0.012%</div></div>
    </div>
  </div>

  <!-- ORDERBOOK -->
  <div class="panel orderbook-panel">
    <div class="panel-header">
      <span class="panel-title">Order Book</span>
      <span class="spread-badge" id="spreadBadge">Spread: 0.50</span>
    </div>
    <div class="ob-headers">
      <span class="ob-head">Price</span>
      <span class="ob-head" style="text-align:center">Size</span>
      <span class="ob-head" style="text-align:right">Total</span>
    </div>
    <div class="ob-rows" id="askRows" style="max-height:180px;"></div>
    <div class="ob-mid">
      <div class="ob-mid-price" id="midPrice">67,432.50</div>
      <div class="ob-mid-usd">≈ $67,432.50</div>
    </div>
    <div class="ob-rows" id="bidRows" style="max-height:180px;"></div>

    <div class="panel-header" style="margin-top:1px;">
      <span class="panel-title">Recent Trades</span>
      <span style="font-family:var(--mono);font-size:10px;color:var(--text3);">LIVE</span>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;padding:5px 14px;">
      <span style="font-family:var(--mono);font-size:10px;color:var(--text3);">PRICE</span>
      <span style="font-family:var(--mono);font-size:10px;color:var(--text3);text-align:center">AMOUNT</span>
      <span style="font-family:var(--mono);font-size:10px;color:var(--text3);text-align:right">TIME</span>
    </div>
    <div class="trade-rows" id="tradeRows" style="max-height:160px;"></div>
  </div>

  <!-- PORTFOLIO -->
  <div class="panel portfolio-panel">
    <div class="panel-header">
      <span class="panel-title">Portfolio</span>
      <span style="font-family:var(--mono);font-size:10px;color:var(--green)">↑ 4.82% today</span>
    </div>
    <div class="port-summary">
      <div class="port-stat">
        <div class="port-stat-label">Total Value</div>
        <div class="port-stat-val" style="color:var(--text1)">$48,291.44</div>
      </div>
      <div class="port-stat">
        <div class="port-stat-label">24h P&L</div>
        <div class="port-stat-val up">+$2,214.82</div>
      </div>
      <div class="port-stat">
        <div class="port-stat-label">Available</div>
        <div class="port-stat-val" style="color:var(--blue)">$5,820.00</div>
      </div>
      <div class="port-stat">
        <div class="port-stat-label">Unrealized</div>
        <div class="port-stat-val" style="color:var(--amber)">+$1,102.50</div>
      </div>
    </div>
    <div class="port-holdings" id="holdingsList"></div>

    <!-- TRADE FORM -->
    <div class="trade-form">
      <div class="trade-tabs">
        <button class="trade-tab buy active" id="buyTab" onclick="setTradeTab('buy')">BUY</button>
        <button class="trade-tab sell" id="sellTab" onclick="setTradeTab('sell')">SELL</button>
      </div>
      <div class="trade-body">
        <div class="form-group">
          <div class="form-label"><span>Price (USDT)</span><span style="color:var(--text2)">Market: 67,432.50</span></div>
