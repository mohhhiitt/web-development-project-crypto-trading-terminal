        </div>
        <div class="form-group">
          <div class="form-label"><span>Amount (BTC)</span><span style="color:var(--text2)" id="balLabel">Bal: 0.184 BTC</span></div>
          <input class="form-input" type="text" id="amountInput" value="0.01" placeholder="0.00">
        </div>
        <div class="pct-row">
          <div class="pct-btn" onclick="setPct(25)">25%</div>
          <div class="pct-btn" onclick="setPct(50)">50%</div>
          <div class="pct-btn" onclick="setPct(75)">75%</div>
          <div class="pct-btn" onclick="setPct(100)">MAX</div>
        </div>
        <div class="form-group" style="margin-bottom:10px;">
          <div class="form-label"><span>Total (USDT)</span></div>
          <input class="form-input" type="text" id="totalInput" value="674.33" placeholder="0.00" readonly style="background:var(--bg2);cursor:default;">
        </div>
        <button class="submit-btn buy" id="submitBtn" onclick="placeTrade()">BUY BTC</button>
      </div>
    </div>
  </div>

  <!-- NEWS PANEL -->
  <div class="panel news-panel" style="grid-column:2;grid-row:2;">
    <div class="panel-header">
      <span class="panel-title">Market News</span>
      <span style="font-family:var(--mono);font-size:10px;color:var(--text3)" id="newsClock">--:--:--</span>
    </div>
    <div class="news-list" id="newsList"></div>
  </div>

</div>

<div class="toast" id="toast"></div>

<script>
// ============================================================
// DATA & STATE
// ============================================================
const COINS = [
  { sym: 'BTC', name: 'Bitcoin',  price: 67432.50, change: 2.34,  color: '#f7931a', icon: 'BTC' },
  { sym: 'ETH', name: 'Ethereum', price: 3512.80,  change: -1.18, color: '#627eea', icon: 'ETH' },
  { sym: 'SOL', name: 'Solana',   price: 178.42,   change: 5.61,  color: '#9945ff', icon: 'SOL' },
  { sym: 'BNB', name: 'BNB',      price: 598.10,   change: 0.87,  color: '#f3ba2f', icon: 'BNB' },
  { sym: 'XRP', name: 'Ripple',   price: 0.6124,   change: -0.42, color: '#3b9eff', icon: 'XRP' },
];

const HOLDINGS = [
  { sym: 'BTC', name: 'Bitcoin',  qty: 0.184, avgCost: 63200, color: '#f7931a' },
  { sym: 'ETH', name: 'Ethereum', qty: 2.45,  avgCost: 3120,  color: '#627eea' },
  { sym: 'SOL', name: 'Solana',   qty: 18.5,  avgCost: 152.3, color: '#9945ff' },
  { sym: 'BNB', name: 'BNB',      qty: 3.2,   avgCost: 570,   color: '#f3ba2f' },
];

const NEWS = [
  { source: 'CoinDesk', time: '2m ago',  sentiment: 'bull', headline: 'Bitcoin breaks $67K resistance — analysts target $72K next', coins: ['BTC'] },
  { source: 'Decrypt',  time: '8m ago',  sentiment: 'bull', headline: 'Ethereum ETF inflows hit $420M this week, setting new record', coins: ['ETH'] },
  { source: 'Reuters',  time: '14m ago', sentiment: 'bear', headline: 'Fed signals higher-for-longer rates, crypto markets cautious', coins: ['BTC','ETH'] },
  { source: 'TheBlock', time: '22m ago', sentiment: 'bull', headline: 'Solana DeFi TVL surpasses $8B as meme coin season drives activity', coins: ['SOL'] },
  { source: 'Blockworks',time:'35m ago', sentiment: 'neut', headline: 'Binance receives regulatory approval in new European jurisdiction', coins: ['BNB'] },
  { source: 'CoinTele', time: '51m ago', sentiment: 'bull', headline: 'MicroStrategy adds 5,000 BTC to corporate treasury in latest purchase', coins: ['BTC'] },
  { source: 'Decrypt',  time: '1h ago',  sentiment: 'bear', headline: 'XRP case: SEC files for extension, delays final ruling by 60 days', coins: ['XRP'] },
  { source: 'TheBlock', time: '2h ago',  sentiment: 'neut', headline: 'Crypto venture funding rebounds to $2.1B in Q1 2025', coins: ['BTC','ETH','SOL'] },
  { source: 'CoinDesk', time: '3h ago',  sentiment: 'bull', headline: 'Lightning Network capacity hits all-time high of 5,400 BTC', coins: ['BTC'] },
  { source: 'Blockworks',time:'4h ago',  sentiment: 'bear', headline: 'Galaxy Research downgrades Ethereum citing L2 fee compression', coins: ['ETH'] },
];

let activeCoin = 0;
let tradeSide = 'buy';
let priceChart = null;

// ============================================================
// TICKER STRIP
// ============================================================
function buildTicker() {
  const el = document.getElementById('tickerStrip');
  el.innerHTML = COINS.map((c, i) => `
    <div class="ticker-item ${i === activeCoin ? 'active' : ''}" onclick="selectCoin(${i})">
      <span class="ticker-sym">${c.sym}/USDT</span>
      <span class="ticker-price">$${fmtPrice(c.price)}</span>
      <span class="ticker-change ${c.change >= 0 ? 'up' : 'dn'}">${c.change >= 0 ? '+' : ''}${c.change}%</span>
    </div>
  `).join('');
}

function fmtPrice(p) {
  if (p >= 1000) return p.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});
  if (p >= 1) return p.toFixed(4);
  return p.toFixed(6);
}

function selectCoin(i) {
  activeCoin = i;
  buildTicker();
  updateHeader();
  buildChart();
  buildOrderBook();
  buildTrades();
}

function updateHeader() {
  const c = COINS[activeCoin];
  document.getElementById('pairName').textContent = `${c.sym} / USDT`;
  document.getElementById('pairPrice').textContent = fmtPrice(c.price);
  document.getElementById('midPrice').textContent = fmtPrice(c.price);
  const ch = document.getElementById('pairChange');
  ch.textContent = `${c.change >= 0 ? '+' : ''}${c.change}%`;
  ch.className = c.change >= 0 ? 'up' : 'dn';
}

// ============================================================
// CHART
// ============================================================
function generateCandles(base, n = 60) {
  const data = []; let p = base;
  const now = Date.now();
  for (let i = n; i >= 0; i--) {
    const chg = (Math.random() - 0.48) * base * 0.012;
    const open = p;
    const close = p + chg;
    const high = Math.max(open, close) + Math.random() * base * 0.004;
    const low  = Math.min(open, close) - Math.random() * base * 0.004;
    const vol  = Math.random() * 0.8 + 0.2;
    data.push({ x: now - i * 4 * 3600000, o: open, h: high, l: low, c: close, v: vol });
    p = close;
  }
  return data;
}

function buildChart() {
  const coin = COINS[activeCoin];
  const candles = generateCandles(coin.price);
  const labels = candles.map(c => {
    const d = new Date(c.x);
    return d.toLocaleDateString('en-US', {month:'short',day:'numeric'}) + ' ' + d.toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit',hour12:false});
  });
  const closes  = candles.map(c => +c.c.toFixed(2));
  const volumes = candles.map(c => c.v);
  const colors  = candles.map(c => c.c >= c.o ? 'rgba(0,232,162,0.55)' : 'rgba(255,77,106,0.55)');

  const ctx = document.getElementById('priceChart').getContext('2d');
  if (priceChart) priceChart.destroy();

  // gradient fill
  const grad = ctx.createLinearGradient(0, 0, 0, 260);
  grad.addColorStop(0, 'rgba(0,232,162,0.18)');
  grad.addColorStop(1, 'rgba(0,232,162,0.0)');

  priceChart = new Chart(ctx, {
    type: 'bar',
    data: {
      labels,
      datasets: [
        {
          type: 'line',
          label: 'Price',
          data: closes,
          borderColor: 'rgba(0,232,162,0.9)',
          borderWidth: 1.5,
          pointRadius: 0,
          pointHoverRadius: 4,
          tension: 0.3,
          fill: true,
          backgroundColor: grad,
          yAxisID: 'y',
          order: 1
        },
        {
          type: 'bar',
          label: 'Volume',
          data: volumes,
          backgroundColor: colors,
          borderRadius: 1,
          yAxisID: 'yVol',
          order: 2
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: '#1a2433',
          borderColor: 'rgba(255,255,255,0.1)',
          borderWidth: 1,
          titleColor: '#8899aa',
          bodyColor: '#e8edf2',
          titleFont: { family: 'Space Mono', size: 10 },
          bodyFont: { family: 'Space Mono', size: 11 },
          callbacks: {
            label: ctx => ctx.datasetIndex === 0 ? ` $${ctx.parsed.y.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2})}` : ` Vol: ${ctx.parsed.y.toFixed(2)}K`
          }
        }
      },
      scales: {
        x: {
          ticks: { color: '#4a5c6e', font: { family: 'Space Mono', size: 9 }, maxTicksLimit: 8, maxRotation: 0 },
          grid: { color: 'rgba(255,255,255,0.03)' }
        },
        y: {
          position: 'right',
          ticks: { color: '#4a5c6e', font: { family: 'Space Mono', size: 9 },
            callback: v => '$' + v.toLocaleString('en-US',{minimumFractionDigits:0,maximumFractionDigits:0}) },
          grid: { color: 'rgba(255,255,255,0.04)' }
        },
        yVol: {
          position: 'left',
          max: 5,
          ticks: { display: false },
          grid: { display: false }
        }
      }
    }
  });
}

function setTF(tf) {
  document.querySelectorAll('.tf-btn').forEach(b => b.classList.remove('active'));
  event.target.classList.add('active');
  buildChart();
}

// ============================================================
// ORDER BOOK
// ============================================================
function generateOrderBook(mid, n = 14) {
  const asks = [], bids = [];
  let askTotal = 0, bidTotal = 0;
  for (let i = 1; i <= n; i++) {
    const p = mid + i * (mid * 0.0003);
    const s = +(Math.random() * 3 + 0.05).toFixed(4);
    askTotal += s;
    asks.push({ p: +p.toFixed(2), s, t: +askTotal.toFixed(4) });
  }
  for (let i = 1; i <= n; i++) {
    const p = mid - i * (mid * 0.0003);
    const s = +(Math.random() * 3 + 0.05).toFixed(4);
    bidTotal += s;
    bids.push({ p: +p.toFixed(2), s, t: +bidTotal.toFixed(4) });
  }
  return { asks: asks.reverse(), bids };
}

function buildOrderBook() {
  const coin = COINS[activeCoin];
  const { asks, bids } = generateOrderBook(coin.price);
  const maxT = Math.max(asks[asks.length-1].t, bids[bids.length-1].t);

  const askEl = document.getElementById('askRows');
  askEl.innerHTML = asks.map(r => {
    const w = (r.t / maxT * 100).toFixed(1);
    return `<div class="ob-row">
      <div class="ob-bar ask" style="width:${w}%"></div>
      <span class="ob-price ask">${fmtPrice(r.p)}</span>
      <span class="ob-size">${r.s.toFixed(4)}</span>
      <span class="ob-total">${r.t.toFixed(3)}</span>
    </div>`;
  }).join('');

  const bidEl = document.getElementById('bidRows');
  bidEl.innerHTML = bids.map(r => {
    const w = (r.t / maxT * 100).toFixed(1);
    return `<div class="ob-row">
      <div class="ob-bar bid" style="width:${w}%"></div>
      <span class="ob-price bid">${fmtPrice(r.p)}</span>
      <span class="ob-size">${r.s.toFixed(4)}</span>
      <span class="ob-total">${r.t.toFixed(3)}</span>
    </div>`;
  }).join('');

  const spread = (asks[asks.length-1].p - bids[0].p).toFixed(2);
  document.getElementById('spreadBadge').textContent = `Spread: ${spread}`;
}

// ============================================================
// RECENT TRADES
// ============================================================
function buildTrades() {
  const coin = COINS[activeCoin];
  const rows = [];
  let now = Date.now();
  for (let i = 0; i < 20; i++) {
    const side = Math.random() > 0.5;
    const p = coin.price + (Math.random() - 0.5) * coin.price * 0.002;
    const s = +(Math.random() * 1.5 + 0.001).toFixed(4);
    const ago = Math.floor(Math.random() * 120);
    const d = new Date(now - ago * 1000);
    const t = d.toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit',second:'2-digit',hour12:false});
    rows.push({ side, p: +p.toFixed(2), s, t });
  }
  rows.sort((a, b) => b.t - a.t);
  document.getElementById('tradeRows').innerHTML = rows.map(r => `
    <div class="trade-row">
      <span class="tr-price ${r.side ? 'up' : 'dn'}">${fmtPrice(r.p)}</span>
      <span class="tr-size">${r.s}</span>
      <span class="tr-time">${r.t}</span>
    </div>
  `).join('');
}

// ============================================================
// PORTFOLIO
// ============================================================
function buildPortfolio() {
  const totalVal = HOLDINGS.reduce((sum, h) => {
    const coin = COINS.find(c => c.sym === h.sym);
    return sum + (coin ? coin.price * h.qty : 0);
  }, 0);

  document.getElementById('holdingsList').innerHTML = HOLDINGS.map(h => {
    const coin = COINS.find(c => c.sym === h.sym);
    const val = coin ? coin.price * h.qty : 0;
    const pnl = coin ? (coin.price - h.avgCost) * h.qty : 0;
    const pct = coin ? ((coin.price - h.avgCost) / h.avgCost * 100) : 0;
    const alloc = (val / totalVal * 100).toFixed(1);
    return `
      <div>
        <div class="holding-row" onclick="selectCoin(${COINS.findIndex(c=>c.sym===h.sym)})">
          <div class="holding-icon" style="background:${h.color}22;color:${h.color}">${h.sym.slice(0,3)}</div>
          <div class="holding-info">
            <div class="holding-sym">${h.sym}</div>
            <div class="holding-name">${h.qty} units · ${alloc}% alloc</div>
          </div>
          <div class="holding-right">
            <div class="holding-val">$${val.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2})}</div>
            <div class="holding-pnl ${pnl>=0?'up':'dn'}">${pnl>=0?'+':''}${pct.toFixed(2)}%</div>
          </div>
        </div>
        <div class="holding-bar">
          <div class="holding-bar-fill" style="width:${alloc}%;background:${h.color}"></div>
        </div>
      </div>
    `;
  }).join('');
}

// ============================================================
// TRADE FORM
// ============================================================
function setTradeTab(side) {
  tradeSide = side;
  document.getElementById('buyTab').classList.toggle('active', side === 'buy');
  document.getElementById('sellTab').classList.toggle('active', side === 'sell');
  const btn = document.getElementById('submitBtn');
  btn.textContent = side === 'buy' ? `BUY ${COINS[activeCoin].sym}` : `SELL ${COINS[activeCoin].sym}`;
  btn.className = `submit-btn ${side}`;
}

function setPct(p) {
  const coin = COINS[activeCoin];
  const base = tradeSide === 'buy' ? 5820 / coin.price : 0.184;
  const amt = +(base * p / 100).toFixed(6);
  document.getElementById('amountInput').value = amt;
  document.getElementById('totalInput').value = (amt * coin.price).toFixed(2);
}

document.getElementById('amountInput').addEventListener('input', function() {
  const coin = COINS[activeCoin];
  const p = parseFloat(document.getElementById('priceInput').value) || coin.price;
  const a = parseFloat(this.value) || 0;
  document.getElementById('totalInput').value = (a * p).toFixed(2);
});

function placeTrade() {
  const coin = COINS[activeCoin];
  const amt = document.getElementById('amountInput').value;
  const total = document.getElementById('totalInput').value;
  showToast(`${tradeSide.toUpperCase()} ${amt} ${coin.sym} @ $${parseFloat(total).toLocaleString()} placed`);
}

// ============================================================
// NEWS
// ============================================================
function buildNews() {
  document.getElementById('newsList').innerHTML = NEWS.map(n => `
    <div class="news-item">
      <div class="news-meta">
        <span class="news-source">${n.source}</span>
        <span class="news-time">${n.time}</span>
        <span class="news-sentiment ${n.sentiment}">${n.sentiment === 'bull' ? '▲ BULL' : n.sentiment === 'bear' ? '▼ BEAR' : '— NEUT'}</span>
      </div>
      <div class="news-headline">${n.headline}</div>
      <div class="news-coins">${n.coins.map(c=>`<span class="news-coin-tag">${c}</span>`).join('')}</div>
    </div>
  `).join('');
}

// ============================================================
// CLOCK
// ============================================================
function updateClock() {
  const now = new Date();
  document.getElementById('newsClock').textContent = now.toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit',second:'2-digit',hour12:false}) + ' UTC';
}

// ============================================================
// LIVE PRICE SIMULATION
// ============================================================
function simulatePrices() {
  COINS.forEach(c => {
    const chg = (Math.random() - 0.5) * c.price * 0.0008;
    c.price = Math.max(c.price + chg, 0.001);
  });
  buildTicker();
  updateHeader();
  document.getElementById('midPrice').textContent = fmtPrice(COINS[activeCoin].price);
  buildOrderBook();
  buildPortfolio();
  addTradeRow();
}

function addTradeRow() {
  const coin = COINS[activeCoin];
  const side = Math.random() > 0.5;
  const p = coin.price + (Math.random() - 0.5) * coin.price * 0.001;
  const s = +(Math.random() * 0.8 + 0.005).toFixed(4);
  const now = new Date();
  const t = now.toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit',second:'2-digit',hour12:false});
  const row = document.createElement('div');
  row.className = 'trade-row';
  row.innerHTML = `<span class="tr-price ${side?'up':'dn'}">${fmtPrice(+p.toFixed(2))}</span><span class="tr-size">${s}</span><span class="tr-time">${t}</span>`;
  const tr = document.getElementById('tradeRows');
  tr.insertBefore(row, tr.firstChild);
  if (tr.children.length > 30) tr.removeChild(tr.lastChild);
}

// ============================================================
// TOAST
// ============================================================
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}

// ============================================================
// INIT
// ============================================================
buildTicker();
updateHeader();
buildChart();
buildOrderBook();
buildTrades();
buildPortfolio();
buildNews();
updateClock();

setInterval(simulatePrices, 1800);
setInterval(updateClock, 1000);
</script>
